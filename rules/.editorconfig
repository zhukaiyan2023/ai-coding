# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,json,css,html,yml,yaml,md}]
indent_style = space
indent_size = 2

[*.{js,ts}]
quote_type = single

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
