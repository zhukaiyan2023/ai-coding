#!/bin/sh
# 预提交钩子 - 代码质量检查

# 输出颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "${GREEN}正在运行预提交检查...${NC}"

# 检查 node_modules 是否存在
if [ ! -d "node_modules" ]; then
  echo "${YELLOW}未找到 node_modules。正在运行 npm install...${NC}"
  npm install
fi

# 获取暂存文件列表
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "${YELLOW}没有需要检查的暂存文件。${NC}"
  exit 0
fi

# 检查 TypeScript/JavaScript 文件
TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx)$' | grep -v '\.d\.ts$' | grep -v 'node_modules')

if [ -n "$TS_FILES" ]; then
  echo "${GREEN}正在运行 TypeScript 类型检查...${NC}"
  npx tsc --noEmit
  if [ $? -ne 0 ]; then
    echo "${RED}TypeScript 检查失败！${NC}"
    exit 1
  fi

  echo "${GREEN}正在运行 ESLint...${NC}"
  echo "$TS_FILES" | xargs npx eslint --max-warnings=0
  if [ $? -ne 0 ]; then
    echo "${RED}ESLint 检查失败！${NC}"
    exit 1
  fi

  echo "${GREEN}正在运行 Prettier 检查...${NC}"
  echo "$STAGED_FILES" | xargs npx prettier --check --ignore-unknown
  if [ $? -ne 0 ]; then
    echo "${RED}Prettier 检查失败！运行 'npm run format' 修复。${NC}"
    exit 1
  fi
fi

# 检查 package.json 更改
if echo "$STAGED_FILES" | grep -q "package.json"; then
  echo "${GREEN}正在检查 package.json...${NC}"
  npx check-engine
fi

# 在更改的文件上运行单元测试
if [ -f "jest.config.js" ] || [ -f "jest.config.ts" ]; then
  echo "${GREEN}正在运行单元测试...${NC}"
  npx jest --passWithNoTests
  if [ $? -ne 0 ]; then
    echo "${RED}测试失败！${NC}"
    exit 1
  fi
fi

echo "${GREEN}所有预提交检查通过！${NC}"
exit 0
