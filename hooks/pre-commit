#!/bin/sh
# Pre-commit hook for code quality checks

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "${GREEN}Running pre-commit checks...${NC}"

# Check if node_modules exists
if [ ! -d "node_modules" ]; then
  echo "${YELLOW}node_modules not found. Running npm install...${NC}"
  npm install
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "${YELLOW}No staged files to check.${NC}"
  exit 0
fi

# Check for TypeScript/JavaScript files
TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx)$' | grep -v '\.d\.ts$' | grep -v 'node_modules')

if [ -n "$TS_FILES" ]; then
  echo "${GREEN}Running TypeScript type check...${NC}"
  npx tsc --noEmit
  if [ $? -ne 0 ]; then
    echo "${RED}TypeScript check failed!${NC}"
    exit 1
  fi

  echo "${GREEN}Running ESLint...${NC}"
  echo "$TS_FILES" | xargs npx eslint --max-warnings=0
  if [ $? -ne 0 ]; then
    echo "${RED}ESLint check failed!${NC}"
    exit 1
  fi

  echo "${GREEN}Running Prettier check...${NC}"
  echo "$STAGED_FILES" | xargs npx prettier --check --ignore-unknown
  if [ $? -ne 0 ]; then
    echo "${RED}Prettier check failed! Run 'npm run format' to fix.${NC}"
    exit 1
  fi
fi

# Check for package.json changes
if echo "$STAGED_FILES" | grep -q "package.json"; then
  echo "${GREEN}Checking package.json...${NC}"
  npx check-engine
fi

# Run unit tests on changed files
if [ -f "jest.config.js" ] || [ -f "jest.config.ts" ]; then
  echo "${GREEN}Running unit tests...${NC}"
  npx jest --passWithNoTests
  if [ $? -ne 0 ]; then
    echo "${RED}Tests failed!${NC}"
    exit 1
  fi
fi

echo "${GREEN}All pre-commit checks passed!${NC}"
exit 0
