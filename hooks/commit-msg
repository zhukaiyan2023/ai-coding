#!/bin/sh
# 提交信息钩子 - 约定式提交

# 输出颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# 约定式提交模式
# type(scope): 描述
# 或
# type: 描述

PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|release)(\(.+\))?: .{1,100}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo "${RED}无效的提交信息格式！${NC}"
  echo "${YELLOW}预期格式：${NC}"
  echo "  feat(auth): 添加登录功能"
  echo "  fix: 修复头部 bug"
  echo "  docs: 更新 README"
  echo ""
  echo "${YELLOW}允许的类型：${NC}"
  echo "  feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert, release"
  echo ""
  echo "${YELLOW}示例：${NC}"
  echo "  feat(component): 添加 Button 组件"
  echo "  fix(api): 解决用户认证问题"
  echo "  docs: 更新 API 文档"
  exit 1
fi

# 检查 issue 引用
if ! echo "$COMMIT_MSG" | grep -qE "(#[0-9]+|closes|fixes|resolves)"; then
  echo "${YELLOW}警告：建议引用 issue（例如 'Fixes #123'）${NC}"
fi

# 检查提交信息长度
LINES=$(echo "$COMMIT_MSG" | wc -l)
if [ "$LINES" -gt 1 ]; then
  BODY=$(echo "$COMMIT_MSG" | tail -n +2)
  if [ ${#BODY} -gt 100 ]; then
    echo "${YELLOW}警告：提交正文每行应该少于 100 个字符${NC}"
  fi
fi

echo "${GREEN}提交信息验证通过！${NC}"
exit 0
