#!/bin/sh
# Commit message hook for conventional commits

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Conventional commit pattern
# type(scope): description
# or
# type: description

PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|release)(\(.+\))?: .{1,100}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo "${RED}Invalid commit message format!${NC}"
  echo "${YELLOW}Expected format:${NC}"
  echo "  feat(auth): add login functionality"
  echo "  fix: resolve header bug"
  echo "  docs: update README"
  echo ""
  echo "${YELLOW}Allowed types:${NC}"
  echo "  feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert, release"
  echo ""
  echo "${YELLOW}Examples:${NC}"
  echo "  feat(component): add Button component"
  echo "  fix(api): resolve user authentication issue"
  echo "  docs: update API documentation"
  exit 1
fi

# Check for issue reference
if ! echo "$COMMIT_MSG" | grep -qE "(#[0-9]+|closes|fixes|resolves)"; then
  echo "${YELLOW}Warning: Consider referencing an issue (e.g., 'Fixes #123')${NC}"
fi

# Check commit message length
LINES=$(echo "$COMMIT_MSG" | wc -l)
if [ "$LINES" -gt 1 ]; then
  BODY=$(echo "$COMMIT_MSG" | tail -n +2)
  if [ ${#BODY} -gt 100 ]; then
    echo "${YELLOW}Warning: Commit body lines should be under 100 characters${NC}"
  fi
fi

echo "${GREEN}Commit message validated!${NC}"
exit 0
