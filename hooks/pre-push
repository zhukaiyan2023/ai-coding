#!/bin/sh
# 预推送钩子 - 安全和构建验证

# 输出颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "${GREEN}正在运行预推送检查...${NC}"

# 获取当前分支
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

# 检查是否推送到 main/master
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo "${YELLOW}你即将直接推送到 $BRANCH！${NC}"
  read -p "确定吗？(y/n) " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "${YELLOW}推送已取消。${NC}"
    exit 1
  fi
fi

# 检查安全漏洞
if [ -f "package.json" ]; then
  echo "${GREEN}正在检查安全漏洞...${NC}"
  npx audit-ci --config .auditci.json 2>/dev/null || npm audit --audit-level=high
  if [ $? -ne 0 ]; then
    echo "${RED}发现安全漏洞！${NC}"
    exit 1
  fi
fi

# 运行完整测试套件
if [ -f "jest.config.js" ] || [ -f "jest.config.ts" ]; then
  echo "${GREEN}正在运行完整测试套件...${NC}"
  npx jest --coverage --passWithNoTests
  if [ $? -ne 0 ]; then
    echo "${RED}测试失败！${NC}"
    exit 1
  fi
fi

# 构建检查
if [ -f "package.json" ]; then
  echo "${GREEN}正在构建项目...${NC}"
  npm run build
  if [ $? -ne 0 ]; then
    echo "${RED}构建失败！${NC}"
    exit 1
  fi
fi

echo "${GREEN}所有预推送检查通过！${NC}"
exit 0
