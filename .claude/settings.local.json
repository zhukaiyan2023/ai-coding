{
  "permissions": {
    "allow": [
      "Skill(update-config)",
      "Bash(node:*)",
      "WebSearch",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(wc:*)",
      "Bash(mvn:*)",
      "Bash(npm:*)",
      "Bash(python:*)",
      "Bash( pytest:*)",
      "WebFetch(domain:github.com)",
      "Bash(gh api:*)",
      "Bash(curl -s https://api.github.com/repos/karanb192/awesome-claude-skills/contents/readme.md)",
      "Bash(python3 -c \"import sys,json; print\\(base64.b64decode\\(json.load\\(sys.stdin\\)[''''content'''']\\).decode\\(\\)\\)\")",
      "Bash(curl -sL https://raw.githubusercontent.com/karanb192/awesome-claude-skills/main/README.md)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:plugins.jetbrains.com)",
      "Bash(grep -E \"^\\\\#{2,3}\\\\s+\")",
      "Bash(grep -E \"^\\\\*\\\\*\\\\*.+\\\\*\\\\*$|^\\\\*\\\\*Source\\\\*\\\\*|^\\\\*\\\\*Status\\\\*\\\\*|^\\\\*\\\\*Description\\\\*\\\\*|^#### \")",
      "Read(//Users/kaiyan/.claude/skills/**)",
      "Read(//Users/kaiyan/.claude/**)",
      "Bash(gh repo:*)",
      "Bash(python3 -c \"import sys,json; print\\(json.load\\(sys.stdin\\)[''''content'''']\\)\")",
      "Bash(GIT_CURL_NO_SSL_REVOKE=1 git push 2>&1)",
      "Bash(GIT_TRACE=1 GIT_CURL_VERBOSE=1 git push)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/user_prompt_submit.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre_tool_use.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pre_dev_check.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post_tool_use.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/post_dev_review.js"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-docs-update.js"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/code-quality.js"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/complexity-check.js"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/lint-check.js"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/test-verify.js"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post_tool_use_failure.js"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/task_completed.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/stop.js"
          }
        ]
      }
    ]
  }
}
